@@ -0,0 +1,28 @@
+import os
+import json
+import logging
+
+logger = logging.getLogger(__name__)
+
+
+def load_config(path: str) -> dict:
+    """Load and parse a JSON config file.
+
+    Returns an empty dict if the file does not exist.
+    """
+    # BUG: TOCTOU race — file could be deleted or replaced
+    # between the isfile() check and the open() call
+    if not os.path.isfile(path):
+        logger.warning("Config file %s not found, using defaults", path)
+        return {}
+
+    with open(path, "r") as f:
+        data = json.load(f)
+
+    if not isinstance(data, dict):
+        raise ValueError(f"Expected dict in {path}, got {type(data).__name__}")
+
+    logger.info("Loaded config from %s (%d keys)", path, len(data))
+    return data
