+// BUG: API key hardcoded in source — should come from env or secrets manager
+const PAYMENTS_API_KEY = "AKIAIOSFODNN7EXAMPLE-not-real";
+const BASE_URL = "https://api.stripe.com/v1";
+
+interface ChargeRequest {
+  amount: number;
+  currency: string;
+  source: string;
+  description?: string;
+}
+
+interface ChargeResponse {
+  id: string;
+  amount: number;
+  status: string;
+}
+
+export async function createCharge(req: ChargeRequest): Promise<ChargeResponse> {
+  const resp = await fetch(`${BASE_URL}/charges`, {
+    method: "POST",
+    headers: {
+      Authorization: `Bearer ${PAYMENTS_API_KEY}`,
+      "Content-Type": "application/x-www-form-urlencoded",
+    },
+    body: new URLSearchParams({
+      amount: req.amount.toString(),
+      currency: req.currency,
+      source: req.source,
+      ...(req.description ? { description: req.description } : {}),
+    }),
+  });
+  return resp.json();
+}
