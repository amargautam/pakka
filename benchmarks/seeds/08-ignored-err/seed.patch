--- /dev/null
+++ b/config/writer.go
@@ -0,0 +1,28 @@
+package config
+
+import (
+	"encoding/json"
+	"os"
+)
+
+type AppConfig struct {
+	Host     string `json:"host"`
+	Port     int    `json:"port"`
+	LogLevel string `json:"log_level"`
+	Workers  int    `json:"workers"`
+}
+
+func WriteConfig(path string, cfg *AppConfig) {
+	data, _ := json.MarshalIndent(cfg, "", "  ")
+
+	// BUG: errors from os.Create and f.Write are discarded with _
+	// If the file can't be created or written, failure is silent
+	f, _ := os.Create(path)
+	defer f.Close()
+
+	_, _ = f.Write(data)
+	_, _ = f.Write([]byte("\n"))
+}
+
+func DefaultConfig() *AppConfig {
+	return &AppConfig{Host: "0.0.0.0", Port: 8080, LogLevel: "info", Workers: 4}
+}
