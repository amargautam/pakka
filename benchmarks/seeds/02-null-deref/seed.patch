--- /dev/null
+++ b/db/user.go
@@ -0,0 +1,25 @@
+package db
+
+import (
+	"database/sql"
+	"fmt"
+)
+
+type User struct {
+	ID    int
+	Name  string
+	Email string
+}
+
+func GetUserByID(db *sql.DB, id int) (*User, error) {
+	var u User
+	row := db.QueryRow("SELECT id, name, email FROM users WHERE id = ?", id)
+	// BUG: error from Scan is discarded; if no row exists,
+	// sql.ErrNoRows is lost and u is a zero-value struct
+	row.Scan(&u.ID, &u.Name, &u.Email)
+
+	if u.ID == 0 {
+		return nil, fmt.Errorf("user not found")
+	}
+	return &u, nil
+}
