--- /dev/null
+++ b/lint/runner.ts
@@ -0,0 +1,28 @@
+import { exec } from "child_process";
+import { promisify } from "util";
+
+const execAsync = promisify(exec);
+
+interface LintResult {
+  file: string;
+  passed: boolean;
+  output: string;
+  errors: number;
+}
+
+// BUG: Shell injection — filename is interpolated directly into shell command
+// A filename like "file; rm -rf /" would execute arbitrary commands
+export async function lintFile(filename: string): Promise<LintResult> {
+  const { stdout, stderr } = await execAsync(`eslint --format json ${filename}`);
+
+  const parsed = JSON.parse(stdout);
+  const errorCount = parsed[0]?.errorCount ?? 0;
+
+  return {
+    file: filename,
+    passed: errorCount === 0,
+    output: stdout,
+    errors: errorCount,
+  };
+}
