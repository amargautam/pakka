@@ -0,0 +1,30 @@
+import sqlite3
+import hashlib
+from dataclasses import dataclass
+from typing import Optional
+
+
+@dataclass
+class User:
+    id: int
+    username: str
+    email: str
+    role: str
+
+
+def authenticate(db: sqlite3.Connection, username: str, password: str) -> Optional[User]:
+    """Authenticate a user by username and password."""
+    pw_hash = hashlib.sha256(password.encode()).hexdigest()
+
+    # BUG: SQL injection — f-string interpolation of user-supplied username
+    query = f"SELECT id, username, email, role FROM users WHERE username = '{username}' AND pw_hash = '{pw_hash}'"
+    cursor = db.execute(query)
+    row = cursor.fetchone()
+
+    if row is None:
+        return None
+
+    return User(id=row[0], username=row[1], email=row[2], role=row[3])
